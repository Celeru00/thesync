APP_NAME=ThesisSync Backend
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SQLALCHEMY_ECHO=false

# Frontend origin allowed by CORS.
FRONTEND_URL=http://localhost:3000

# Supabase auth verification.
# SUPABASE_URL can be inferred from DATABASE_URL when using a hosted Supabase Postgres URL,
# but keeping it explicit is still recommended.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_LEEWAY_SECONDS=60

# Optional fallback only for projects still using a symmetric JWT secret.
# Leave blank when your project uses asymmetric signing keys with JWKS.
SUPABASE_JWT_SECRET=

# Google Calendar integration.
# Use the same Google OAuth client configured in Supabase so the backend can
# refresh each user's Google Calendar token securely.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar

# Optional: backend manual deploy trigger for Render.
RENDER_DEPLOY_HOOK_URL=
