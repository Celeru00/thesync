APP_NAME=ThesisSync Backend
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SQLALCHEMY_ECHO=false

# Frontend origin allowed by CORS.
FRONTEND_URL=http://localhost:3000

# Supabase auth verification.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Optional fallback only for projects still using a symmetric JWT secret.
# Leave blank when your project uses asymmetric signing keys with JWKS.
SUPABASE_JWT_SECRET=

# Optional: backend manual deploy trigger for Render.
RENDER_DEPLOY_HOOK_URL=
